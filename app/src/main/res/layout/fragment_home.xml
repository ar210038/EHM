<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F6"
    tools:showIn="@layout/activity_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ===== TOP BAR: App name + connection status ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EHM"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A6B8A" />

            <!-- connection status pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_pill_safe"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Connected"
                    android:textSize="12sp"
                    android:textColor="#0F6E56" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== LAST UPDATED LABEL ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last updated 4 seconds ago"
            android:textSize="12sp"
            android:textColor="#9AA5A3"
            android:layout_marginBottom="16dp" />

        <!-- ===== HEALTH RISK SCORE CARD ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HEALTH RISK SCORE"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="#9AA5A3"
                    android:layout_marginBottom="12dp" />

                <!-- Circular score ring -->
                <FrameLayout
                    android:layout_width="160dp"
                    android:layout_height="160dp">

                    <!-- Background ring -->
                    <ProgressBar
                        android:id="@+id/scoreRingBg"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="100"
                        android:progressDrawable="@drawable/ring_track"
                        android:rotation="-90" />

                    <!-- Foreground progress ring -->
                    <ProgressBar
                        android:id="@+id/scoreRing"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="72"
                        android:progressDrawable="@drawable/ring_progress_danger"
                        android:rotation="-90" />

                    <!-- Center text -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/scoreValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="72"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:textColor="#993C1D" />

                        <TextView
                            android:id="@+id/scoreLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High Risk"
                            android:textSize="14sp"
                            android:textColor="#993C1D" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Cause subtitle -->
                <TextView
                    android:id="@+id/causeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Mainly due to Air Quality (AQI 162)"
                    android:textSize="13sp"
                    android:textColor="#5B6664"
                    android:gravity="center" />

                <!-- Suggestion box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_suggestion_box"
                    android:padding="14dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="18sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/suggestionText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Open a window or move to a ventilated area until air quality improves."
                        android:textSize="13sp"
                        android:textColor="#1A3A50"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION LABEL ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Readings"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A3A50"
            android:layout_marginBottom="10dp" />

        <!-- ===== SENSOR CARDS — 2x2 GRID ===== -->
        <!-- Row 1: Temperature + Humidity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- Temperature card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EDFBF4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌡️ Temperature"
                        android:textSize="12sp"
                        android:textColor="#0F6E56"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tempValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="29.4°C"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#1A3A50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Safe range"
                        android:textSize="11sp"
                        android:textColor="#0F6E56"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Humidity card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FEF9EE">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧 Humidity"
                        android:textSize="12sp"
                        android:textColor="#BA7517"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/humidityValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="78%"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#1A3A50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moderate"
                        android:textSize="11sp"
                        android:textColor="#BA7517"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Row 2: Air Quality + Noise -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- AQI card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FBEAE6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌫️ Air Quality"
                        android:textSize="12sp"
                        android:textColor="#993C1D"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/aqiValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="162 AQI"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#1A3A50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="High risk"
                        android:textSize="11sp"
                        android:textColor="#993C1D"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Noise card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EDFBF4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔊 Noise"
                        android:textSize="12sp"
                        android:textColor="#0F6E56"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/noiseValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="54 dB"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#1A3A50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Safe range"
                        android:textSize="11sp"
                        android:textColor="#0F6E56"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Bottom spacing for nav bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="70dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>